rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return isSignedIn()
        && request.auth.token.email in ['torje@wc2026.local'];
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function gameStarted(gameId) {
      let g = get(/databases/$(database)/documents/games/$(gameId)).data;
      return g.kickoff is timestamp && g.kickoff <= request.time;
    }

    match /users/{uid} {
      allow read: if isSignedIn();                       // names needed for leaderboard
      allow create: if isSignedIn() && request.auth.uid == uid
                    && (request.resource.data.isAdmin == false || isAdminEmail());
      allow update: if isSignedIn() && request.auth.uid == uid
                    && (request.resource.data.isAdmin == resource.data.isAdmin || isAdminEmail());
      allow delete: if false;
    }

    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /guesses/{uid} {
        allow read: if isSignedIn()
                    && (request.auth.uid == uid || gameStarted(gameId));
        allow create, update: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.pick in ['1', 'X', '2']
                    && !gameStarted(gameId);
        allow delete: if false;
      }
    }
  }
}
